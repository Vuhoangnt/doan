<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/danh_gia_dialog_hint"
            android:textColor="@color/admin_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/edtTenDanhGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/danh_gia_hint_ten"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/danh_gia_hint_sao"
            android:textSize="13sp" />

        <RatingBar
            android:id="@+id/ratingDanhGia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:rating="5"
            android:stepSize="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/danh_gia_hint_phong"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spinnerPhongDanhGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/edtNoiDungDanhGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="@string/danh_gia_hint_nd"
            android:inputType="textMultiLine"
            android:minLines="3" />
    </LinearLayout>
</ScrollView>
