<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E8E8E8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/txtHomeTinTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/admin_text_primary"
            android:letterSpacing="0.01"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Tiêu đề tin" />

        <TextView
            android:id="@+id/txtHomeTinDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/admin_text_secondary"
            android:textSize="12sp"
            tools:text="2026-04-01" />

        <TextView
            android:id="@+id/txtHomeTinExcerpt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textColor="@color/admin_text_primary"
            android:textSize="13sp"
            tools:text="Nội dung rút gọn…" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
