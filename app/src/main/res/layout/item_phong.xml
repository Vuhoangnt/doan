<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="7dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp"
    app:strokeColor="@color/admin_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="192dp">

            <ImageView
                android:id="@+id/imgPhong"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/nav_phong"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_room_image" />

            <TextView
                android:id="@+id/txtBadgeTrangThai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:background="#C8E6C9"
                tools:text="Trống" />

            <TextView
                android:id="@+id/txtGiaOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textColor="@color/room_price_on_image"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="500.000 đ/đêm" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/txtTenPhong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/admin_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Phòng Đôi view vườn" />

            <TextView
                android:id="@+id/txtMoTa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:lineSpacingExtra="3dp"
                android:maxLines="2"
                android:textColor="@color/admin_text_secondary"
                android:textSize="14sp"
                tools:text="2 giường, ban công, wifi miễn phí…" />

            <LinearLayout
                android:id="@+id/layoutPhongQlMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_phong_card_meta"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/txtPhongQlMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/admin_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Mã #3 · Tối đa 4 khách" />

                <TextView
                    android:id="@+id/txtPhongTapHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="@color/admin_text_secondary"
                    android:textSize="13sp"
                    tools:text="Chạm để sửa hoặc xóa phòng" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/scrollMiniGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutMiniGallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
