<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/admin_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtPhongLichTlMa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/admin_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="DP-001" />

            <TextView
                android:id="@+id/txtPhongLichTlTrangThai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:background="@drawable/bg_room_badge_dang"
                tools:text="Đang ở" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPhongLichTlPhong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/admin_text_primary"
            android:textSize="13sp"
            tools:text="Phòng Đôi" />

        <TextView
            android:id="@+id/txtPhongLichTlThoiGian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/admin_text_primary"
            android:textSize="13sp"
            tools:text="01/02 → 05/02\n14:00 - 12:00" />

        <TextView
            android:id="@+id/txtPhongLichTlKhach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/admin_text_secondary"
            android:textSize="12sp"
            tools:text="Khách: Nguyễn A · 090…" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
